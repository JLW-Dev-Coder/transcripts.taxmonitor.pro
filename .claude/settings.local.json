{
  "permissions": {
    "allow": [
      "Read(/tmp/**)"
    ]
  },
  "autoApprove": [
    "Write",
    "Edit",
    "Create"
  ],
  "autoApprovePatterns": [
    "**/*.html",
    "**/*.js",
    "**/*.css",
    ".claude/**"
  ],
  "deny": [
    "Bash(rm -rf *)",
    "Bash(curl *)",
    "Bash(wget *)",
    "Write(workers/**)"
  ],
  "maxTurns": 20
}
