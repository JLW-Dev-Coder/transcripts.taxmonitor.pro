{
  "name": "transcript-tax-monitor-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "npx vercel build --yes && npx @cloudflare/next-on-pages --skip-build",
    "pages:build": "npm run cf:build",
    "preview": "npx wrangler pages dev .vercel/output/static",
    "deploy": "npm run cf:build && npx wrangler pages deploy .vercel/output/static --project-name=transcript-taxmonitor-pro-site"
  },
  "dependencies": {
    "next": "^15.2.4",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "vercel": "^47.0.4"
  }
}
